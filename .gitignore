# Built artifacts (reproduced by scripts/build-*.ps1)
/bin/

# Bob memory database (personal data, never commit)
/data/

# Python venvs (reproduced from the per-tool requirements files)
/tools/venv-webui/
/tools/venv-aider/
/tools/venv-litellm/
/tools/venv-eval/

# Open WebUI runtime state (db, uploads, secret key)
/tools/webui-data/
.webui_secret_key

# Models (multi-GB, reproduced by scripts/fetch-models.ps1 from config/models.psd1)
/models/*.gguf
/models/*.part
/models/.hf-cache/
/models/whisper/

# Phase 2 voice assets (reproduced by scripts/setup-voice.ps1)
/bin/voices/
/bin/espeak-ng-data/

# Generated runtime config (reproduced by scripts/gen-llama-swap.ps1 from config/models.psd1)
/config/llama-swap.yaml

# llama.cpp build dir (inside submodule; not tracked by parent anyway)
/external/llama.cpp/build/

# User-local config overrides (gitignored so git pull never clobbers tuning)
/config/user.psd1

# Docker service data volumes and generated env (reproduced by scripts/setup-docker.ps1)
/tools/langfuse-data/
/tools/n8n-data/
/tools/searxng-data/
/tools/compose/.env

# Benchmark results (reproduced by llm eval)
/results/

# misc
*.log
/logs/
/models/manifest.json
