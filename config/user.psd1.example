# config/user.psd1 — Copy this file to user.psd1 and uncomment what you want to change.
# This file is gitignored. Values here shadow defaults in models.psd1.
# Re-run `llm gen` after editing. Changes take effect on next `llm serve`.
@{
    defaults = @{
        # ── Inference: GPU / CPU split ──────────────────────────────────────────
        # ngl       = 80        # GPU layers. Lower to CPU-offload if VRAM overflows.
        # threads   = 16        # CPU threads for BLAS. -1 = auto.

        # ── Inference: KV cache quantization ────────────────────────
        # Quantizes the KV cache to save VRAM with minor quality trade-off.
        # Valid types: f16, bf16, q8_0, q5_1, q5_0, q4_1, q4_0, iq4_nl
        #
        # kvQuantK  = 'q8_0'   # Key cache quant (default). Works on all GPU generations with flash-attn.
        #                       # Pre-Blackwell (sm_75–89, RTX 20/30/40 series): override to q5_1 for
        #                       #   better VRAM savings with good attention fidelity.
        #                       # Blackwell (sm_120+, RTX 50 series): sub-q8_0 types cause a significant
        #                       #   prompt-processing regression with flash-attn — keep at q8_0.
        # kvQuantV  = 'q8_0'   # Value cache quant (default). ~50% VRAM savings vs f16.
        #                       # Pre-Blackwell: q4_0 saves ~75% vs f16 with acceptable quality.
        # kvQuant   = 'q8_0'   # Legacy: override both K and V with same type.
        # kvQuantK  = ''        # Disable KV quant entirely (required for Gemma models): set BOTH of these.
        # kvQuantV  = ''        # Both must be '' — setting only kvQuant='' does NOT disable KV quant.

        # ── Inference: batch sizes ──────────────────────────────────
        # batch     = 512       # Logical batch (-b). 512 = omit flag → llama.cpp uses 2048.
        #                       # Set > 512 (e.g. 2048) to explicitly control.
        # ubatch    = 1024      # Physical GPU batch (-ub). Raise from 512 to cut kernel-launch overhead
        #                       # on long prompts. Must be <= effective batch size.

        # ── Inference: parallel slots ────────────────────────────────────────────
        # parallel  = 2         # Allow 2 concurrent requests (doubles KV VRAM usage).

        # ── Memory: RAM preload ─────────────────────────────────────
        # noMmap    = $true     # Load all models into heap RAM (eliminates page faults on CPU-offloaded
        #                       # layers). Under llama-swap, this cost is paid on EVERY eviction+reload,
        #                       # not just at initial startup. A 17 GB model = 3-30 s per swap.
        #                       # Recommended only when system RAM >= 2x largest model (32+ GB free).
        # noMmap    = $false    # Default: use mmap (lazy page loading from disk).

        # ── Memory: locking ─────────────────────────────────────────
        # mlockBig  = $true     # Lock swap-group models (planner/coder/chat) in physical RAM.
        #                       # Windows: needs SeLockMemoryPrivilege (secpol.msc → User Rights Assignment).
        #                       # Without privilege: silent no-op. Use with noMmap = $true.

        # ── CPU topology: NUMA ──────────────────────────────────────
        # numa      = 'isolate'    # 7950X3D: pins inference threads to starting NUMA node (V-Cache CCD).
        # numa      = 'distribute' # Spreads threads across all NUMA nodes. Benchmark vs isolate.
        # numa      = ''           # Default: disabled.
        # Note: numa applies globally to all models (injected into the shared srv macro).
        # Per-model NUMA override is not supported.

        # ── Ports ────────────────────────────────────────────────────────────────
        # port      = 8081      # Run on alternate port (useful for running two stacks side-by-side).
        # webuiPort = 3001      # Open WebUI on alternate port.

        # ── Other ────────────────────────────────────────────────────────────────
        # maxTokens = 2048      # Increase for longer `llm chat` responses.
        # webuiSecret = 'my-real-secret-here'   # Set before exposing WebUI on LAN.
        # flashAttn = $false    # Disable flash attention (CPU-only inference).

        # ── Langfuse tracing ─────────────────────────────────────────────────────
        # Enable after `llm services start` and setting API keys from Langfuse UI:
        #   $env:LANGFUSE_PUBLIC_KEY = 'pk-lf-...'
        #   $env:LANGFUSE_SECRET_KEY = 'sk-lf-...'
        # Then run `llm gen` to regenerate config/litellm.yaml with callbacks active.
        # langfuseEnabled = $true
    }

    # ── MoE ngl tuning ───────────────────────────────────────────────
    # Override planner's -ngl to set an explicit GPU/CPU layer split.
    # At ngl=99 (default), llama.cpp auto-fits as many layers as possible.
    # At ngl=31, exactly 31 layers go to GPU, the rest to CPU RAM.
    # Benchmark with: llm gen && llm serve && llm bench  (compare tg128)
    #
    # profiles = @{
    #   '16gb' = @{
    #     planner = @{ flags = @('--temp', '0.3', '-ngl', '31') }
    #   }
    # }

    # ── API Pro Models (optional) ────────────────────────────────────────────────
    # Pro models (chat-pro / planner-pro / coder-pro) route litellm → API provider
    # directly — no llama-swap hop. Direct APIs have no platform fee (unlike OpenRouter).
    # All three roles currently use DeepSeek — one key covers all.
    # Multiple providers are supported; enable additional peers and set the relevant env var.
    # Re-run `llm gen` after editing. No restart needed for litellm; `llm litellm stop && llm litellm start` to reload.
    #
    # peers = @{
    #   deepseek = @{
    #     # enabled      = $false      # disable all deepseek pro models (no key required)
    #     # budget       = 15.0        # optional USD hard cap (LiteLLM enforced)
    #     # budgetPeriod = '30d'       # reset period: 1d, 7d, 30d, monthly
    #     pro = @{
    #       # Override individual roles — use hashtable form to set maxTokens or systemPrompt:
    #       # chat    = @{ model = 'deepseek-chat';     maxTokens = 4096 }   # DeepSeek V4
    #       # planner = @{ model = 'deepseek-reasoner'; maxTokens = 8192 }   # DeepSeek R1
    #       # coder   = @{ model = 'deepseek-chat';     maxTokens = 4096 }   # DeepSeek V4
    #     }
    #   }
    #   zhipu = @{
    #     # enabled = $true   # re-enable to route specific roles through Zhipu
    #     pro = @{
    #       # coder = 'glm-4-plus'    # alternative coder model
    #     }
    #   }
    #   # OpenRouter — 300+ models, but adds 5.5% platform fee:
    #   # openrouter = @{
    #   #   enabled       = $true
    #   #   proxy         = 'https://openrouter.ai/api/v1'
    #   #   apiKeyEnv     = 'OPENROUTER_API_KEY'
    #   #   litellmPrefix = 'openrouter'
    #   #   pro = @{
    #   #     chat    = 'deepseek/deepseek-v3.2'
    #   #     planner = 'deepseek/deepseek-r1'
    #   #     coder   = 'z-ai/glm-5.2'
    #   #   }
    #   # }
    # }
}
