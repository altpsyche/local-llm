# config/user.psd1 — Copy this file to user.psd1 and uncomment what you want to change.
# This file is gitignored. Values here shadow defaults in models.psd1.
# Re-run `llm gen` after editing. Changes take effect on next `llm serve`.
@{
    defaults = @{
        # ngl         = 80        # Leave VRAM headroom if running other GPU apps alongside.
        # kvQuant     = 'q4_0'    # Halve KV cache VRAM at slight quality cost.
        # kvQuant     = ''        # Disable KV quant entirely (required for Gemma models).
        # flashAttn   = $false    # Disable flash attention (CPU-only inference).
        # threads     = 8         # Fix thread count if auto-detect picks wrong cores.
        # batch       = 1024      # Increase for faster long-prompt processing.
        # parallel    = 2         # Allow 2 concurrent requests (doubles KV VRAM usage).
        # port        = 8081      # Run on alternate port (useful for running two stacks).
        # webuiPort   = 3001      # Open WebUI on alternate port.
        # maxTokens   = 2048      # Increase for longer `llm chat` responses.
        # webuiSecret = 'my-real-secret-here'   # Set before exposing WebUI on LAN.
    }
}
